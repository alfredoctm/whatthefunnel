{
  "name": "@wtf/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build:js && npm run build:css && npm run build:html",
    "build:js": "esbuild src/main.tsx --bundle --format=esm --outdir=dist --minify --target=es2022 --sourcemap --jsx=automatic",
    "build:css": "tailwindcss -i src/index.css -o dist/index.css --minify",
    "build:html": "cp index.html dist/index.html",
    "dev": "mkdir -p dist && cp index.html dist/index.html && (tailwindcss -i src/index.css -o dist/index.css --watch & esbuild src/main.tsx --bundle --format=esm --outdir=dist --target=es2022 --sourcemap --jsx=automatic --watch & wait)",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.4.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.0"
  }
}
