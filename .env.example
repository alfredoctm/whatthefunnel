# WTF — config surface for the api service.
# Copy to `.env` and adjust for local dev.  `.env` is gitignored.

# ClickHouse HTTP endpoint.
# Inside docker-compose, services reach each other by service name:
#   docker:  http://clickhouse:8123
# From host (when running api outside compose, e.g. `npm run dev`):
#   host:    http://localhost:8123
CLICKHOUSE_URL=http://localhost:8123

# ClickHouse credentials. The dedicated `wtf` user is created by
# clickhouse/users.d/wtf-user.xml on container start. The shipped `default`
# user is restricted to localhost-only inside the container — do not use it.
# Change the password for any non-local deployment.
CLICKHOUSE_USER=wtf
CLICKHOUSE_PASSWORD=wtf

# Port Fastify binds to.
PORT=3000

# Pino log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info
