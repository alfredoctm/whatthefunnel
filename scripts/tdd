#!/usr/bin/env bash
# Manage TDD phase state for the outside-in TDD enforcement hook.
#
# State is stored in .claude/tdd-state (per-working-tree, gitignored).
# Values: RED | GREEN | UNLOCK
#
# Commands:
#   scripts/tdd red <test-id>           — declare RED phase (failing test exists)
#   scripts/tdd green                   — verify slice (npm run test:fast + typecheck),
#                                          then flip to GREEN. Refuses if either fails.
#                                          Bootstraps silently if api/package.json doesn't exist yet.
#   scripts/tdd unlock "<reason>"       — explicit override (audited)
#   scripts/tdd status                  — print current state
#
# `green` requires api/package.json to define three npm scripts:
#   "test:fast": runs unit + acceptance tiers (NOT integration)
#   "typecheck": runs `tsc --noEmit`
#   "lint":      runs `eslint . --ext .ts`
# These are added in Phase 1's Tooling decisions block.
#
# `red` writes state directly without verification — it's a claim about a failing
# test that the developer/AI just observed. The hard gate is `green`.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
STATE_FILE="$REPO_ROOT/.claude/tdd-state"
AUDIT="$REPO_ROOT/scripts/audit"

CMD="${1:-status}"

case "$CMD" in
  red)
    TEST_ID="${2:?test id required, e.g. scripts/tdd red api/test/acceptance/ingest.test.js}"
    mkdir -p "$(dirname "$STATE_FILE")"
    printf 'RED\n' > "$STATE_FILE"
    "$AUDIT" tdd_red "$(jq -nc --arg t "$TEST_ID" '{test: $t}')"
    echo "TDD state: RED  (failing test: $TEST_ID)"
    echo "You may now edit api/src/**."
    ;;
  green)
    PKG="$REPO_ROOT/api/package.json"
    NODE_MODULES="$REPO_ROOT/api/node_modules"
    SRC_DIR="$REPO_ROOT/api/src"

    # Bootstrap: before package.json / node_modules exist, OR before the first
    # .ts file lands in api/src/, there's nothing to verify. Allow flipping to
    # GREEN and audit the bootstrap. Once production code exists, every flip
    # is a real test+typecheck gate.
    if [ ! -f "$PKG" ] || [ ! -d "$NODE_MODULES" ]; then
      mkdir -p "$(dirname "$STATE_FILE")"
      printf 'GREEN\n' > "$STATE_FILE"
      "$AUDIT" tdd_green '{"bootstrap": true, "note": "no api/package.json or node_modules — verification skipped"}'
      echo "TDD state: GREEN  (bootstrap — verification skipped, no api/package.json yet)"
      echo "api/src/** is locked again — write a new failing test to unlock."
      exit 0
    fi

    if [ ! -d "$SRC_DIR" ] || [ -z "$(find "$SRC_DIR" -type f -name '*.ts' 2>/dev/null | head -n 1)" ]; then
      mkdir -p "$(dirname "$STATE_FILE")"
      printf 'GREEN\n' > "$STATE_FILE"
      "$AUDIT" tdd_green '{"bootstrap": true, "note": "no .ts files under api/src/ yet — verification skipped"}'
      echo "TDD state: GREEN  (bootstrap — verification skipped, no api/src/**/*.ts yet)"
      echo "api/src/** is locked again — write a new failing test to unlock."
      exit 0
    fi

    # Real gate: tests + typecheck must pass before state flips to GREEN.
    echo "Running npm run test:fast (unit + acceptance tiers)..."
    if ! (cd "$REPO_ROOT/api" && npm run --silent test:fast); then
      echo "" >&2
      echo "TDD green: REFUSED — tests failed. State unchanged." >&2
      echo "Fix the failing tests, or: scripts/tdd unlock \"<reason>\"" >&2
      "$AUDIT" tdd_green_refused '{"reason": "tests failed"}'
      exit 1
    fi

    echo "Running npm run typecheck (tsc --noEmit)..."
    if ! (cd "$REPO_ROOT/api" && npm run --silent typecheck); then
      echo "" >&2
      echo "TDD green: REFUSED — type errors. State unchanged." >&2
      echo "Fix the type errors, or: scripts/tdd unlock \"<reason>\"" >&2
      "$AUDIT" tdd_green_refused '{"reason": "typecheck failed"}'
      exit 1
    fi

    echo "Running npm run lint (eslint)..."
    if ! (cd "$REPO_ROOT/api" && npm run --silent lint); then
      echo "" >&2
      echo "TDD green: REFUSED — lint errors. State unchanged." >&2
      echo "Fix manually, or try: cd api && npm run lint:fix" >&2
      echo "Or override: scripts/tdd unlock \"<reason>\"" >&2
      "$AUDIT" tdd_green_refused '{"reason": "lint failed"}'
      exit 1
    fi

    mkdir -p "$(dirname "$STATE_FILE")"
    printf 'GREEN\n' > "$STATE_FILE"
    "$AUDIT" tdd_green '{"tests": "passed", "typecheck": "passed", "lint": "passed"}'
    echo "TDD state: GREEN  (tests + typecheck + lint passed)"
    echo "api/src/** is locked again — write a new failing test to unlock."
    ;;
  unlock)
    REASON="${2:?reason required, e.g. scripts/tdd unlock \"scaffolding initial Fastify boot\"}"
    mkdir -p "$(dirname "$STATE_FILE")"
    printf 'UNLOCK\n' > "$STATE_FILE"
    "$AUDIT" tdd_unlock "$(jq -nc --arg r "$REASON" '{reason: $r}')"
    echo "TDD state: UNLOCK  (reason: $REASON)"
    echo "Hook will allow api/src/** edits. Run \`scripts/tdd green\` when done."
    ;;
  status)
    if [ -f "$STATE_FILE" ]; then
      printf 'TDD state: '
      cat "$STATE_FILE"
    else
      echo "TDD state: (none — api/src/** is locked)"
    fi
    ;;
  *)
    echo "Unknown command: $CMD" >&2
    echo "Usage: scripts/tdd {red <test-id>|green|unlock <reason>|status}" >&2
    exit 2
    ;;
esac
